<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>t_load_kpi</name>
    <description>Carga out/kpi_por_endpoint_dia.csv a SQLite (staging + fact), con tipificacion y validacion de filas (FR-14).</description>
    <extended_description/>
    <trans_version/>
    <trans_type>Normal</trans_type>
    <trans_status>0</trans_status>
    <directory>/</directory>
    <parameters>
    </parameters>
    <log>
      <trans-log-table>
        <connection/>
        <schema/>
        <table/>
        <size_limit_lines/>
        <interval/>
        <timeout_days/>
      </trans-log-table>
      <perf-log-table>
        <connection/>
        <schema/>
        <table/>
        <interval/>
        <timeout_days/>
      </perf-log-table>
      <channel-log-table>
        <connection/>
        <schema/>
        <table/>
        <timeout_days/>
      </channel-log-table>
      <step-log-table>
        <connection/>
        <schema/>
        <table/>
        <timeout_days/>
      </step-log-table>
      <metrics-log-table>
        <connection/>
        <schema/>
        <table/>
        <timeout_days/>
      </metrics-log-table>
    </log>
    <maxdate>
      <connection/>
      <table/>
      <field/>
      <offset>0.0</offset>
      <maxdiff>0.0</maxdiff>
    </maxdate>
    <size_rowset>10000</size_rowset>
    <sleep_time_empty>50</sleep_time_empty>
    <sleep_time_full>50</sleep_time_full>
    <unique_connections>N</unique_connections>
    <feedback_shown>Y</feedback_shown>
    <feedback_size>50000</feedback_size>
    <using_thread_priorities>Y</using_thread_priorities>
    <shared_objects_file/>
    <capture_step_performance>N</capture_step_performance>
    <step_performance_capturing_delay>1000</step_performance_capturing_delay>
    <step_performance_capturing_size_limit>100</step_performance_capturing_size_limit>
    <dependencies>
    </dependencies>
    <partitionschemas>
    </partitionschemas>
    <slaveservers>
    </slaveservers>
    <clusterschemas>
    </clusterschemas>
    <created_user>-</created_user>
    <created_date>2026/07/12 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/07/12 00:00:00.000</modified_date>
  </info>
  <notepads>
  </notepads>
  <connection>
    <name>sqlite_kpi</name>
    <server/>
    <type>SQLITE</type>
    <access>Native</access>
    <database>${Internal.Transformation.Filename.Directory}/db/kpi.sqlite</database>
    <port/>
    <username/>
    <password/>
    <servername/>
    <data_tablespace/>
    <index_tablespace/>
    <attributes>
    </attributes>
  </connection>
  <order>
    <hop>
      <from>CSV Input</from>
      <to>Tipificar columnas</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Tipificar columnas</from>
      <to>Filter Rows</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Filter Rows</from>
      <to>Staging (Truncate)</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Filter Rows</from>
      <to>Fact (Truncate)</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <step>
    <name>CSV Input</name>
    <type>CsvInput</type>
    <description>Lee out/kpi_por_endpoint_dia.csv (contrato v1.0, FR-10).</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <filename>${Internal.Transformation.Filename.Directory}/../out/kpi_por_endpoint_dia.csv</filename>
    <filename_field/>
    <rownum_field/>
    <include_filename>N</include_filename>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <header>Y</header>
    <buffer_size>50000</buffer_size>
    <lazy_conversion>N</lazy_conversion>
    <add_filename_result>N</add_filename_result>
    <parallel>N</parallel>
    <newline_possible>N</newline_possible>
    <encoding>UTF-8</encoding>
    <fields>
      <field>
        <name>date_utc</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
      </field>
      <field>
        <name>endpoint_base</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
      </field>
      <field>
        <name>requests_total</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
      </field>
      <field>
        <name>success_2xx</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
      </field>
      <field>
        <name>client_4xx</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
      </field>
      <field>
        <name>server_5xx</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
      </field>
      <field>
        <name>parse_errors</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
      </field>
      <field>
        <name>avg_elapsed_ms</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
      </field>
      <field>
        <name>p90_elapsed_ms</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
      </field>
    </fields>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>96</xloc>
      <yloc>96</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
  <step>
    <name>Tipificar columnas</name>
    <type>SelectValues</type>
    <description>Asigna tipos Integer/Number a las columnas numericas (FR-14). date_utc queda
    como String: la columna SQLite destino es TEXT 'YYYY-MM-DD' y el CSV ya trae ese formato
    exacto; convertirla a tipo Fecha hace que el driver JDBC de SQLite la guarde como epoch
    en milisegundos, contradiciendo el contrato (probado empiricamente con Pan.bat).</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <select_unspecified>Y</select_unspecified>
      <meta>
        <name>requests_total</name>
        <rename/>
        <type>Integer</type>
        <length>-1</length>
        <precision>-1</precision>
        <conversion_mask>#</conversion_mask>
        <date_format_lenient>false</date_format_lenient>
        <date_format_locale/>
        <date_format_timezone/>
        <lenient_string_to_number>false</lenient_string_to_number>
        <encoding/>
        <decimal_symbol/>
        <grouping_symbol/>
        <currency_symbol/>
        <storage_type/>
      </meta>
      <meta>
        <name>success_2xx</name>
        <rename/>
        <type>Integer</type>
        <length>-1</length>
        <precision>-1</precision>
        <conversion_mask>#</conversion_mask>
        <date_format_lenient>false</date_format_lenient>
        <date_format_locale/>
        <date_format_timezone/>
        <lenient_string_to_number>false</lenient_string_to_number>
        <encoding/>
        <decimal_symbol/>
        <grouping_symbol/>
        <currency_symbol/>
        <storage_type/>
      </meta>
      <meta>
        <name>client_4xx</name>
        <rename/>
        <type>Integer</type>
        <length>-1</length>
        <precision>-1</precision>
        <conversion_mask>#</conversion_mask>
        <date_format_lenient>false</date_format_lenient>
        <date_format_locale/>
        <date_format_timezone/>
        <lenient_string_to_number>false</lenient_string_to_number>
        <encoding/>
        <decimal_symbol/>
        <grouping_symbol/>
        <currency_symbol/>
        <storage_type/>
      </meta>
      <meta>
        <name>server_5xx</name>
        <rename/>
        <type>Integer</type>
        <length>-1</length>
        <precision>-1</precision>
        <conversion_mask>#</conversion_mask>
        <date_format_lenient>false</date_format_lenient>
        <date_format_locale/>
        <date_format_timezone/>
        <lenient_string_to_number>false</lenient_string_to_number>
        <encoding/>
        <decimal_symbol/>
        <grouping_symbol/>
        <currency_symbol/>
        <storage_type/>
      </meta>
      <meta>
        <name>parse_errors</name>
        <rename/>
        <type>Integer</type>
        <length>-1</length>
        <precision>-1</precision>
        <conversion_mask>#</conversion_mask>
        <date_format_lenient>false</date_format_lenient>
        <date_format_locale/>
        <date_format_timezone/>
        <lenient_string_to_number>false</lenient_string_to_number>
        <encoding/>
        <decimal_symbol/>
        <grouping_symbol/>
        <currency_symbol/>
        <storage_type/>
      </meta>
      <meta>
        <name>avg_elapsed_ms</name>
        <rename/>
        <type>Number</type>
        <length>-1</length>
        <precision>2</precision>
        <conversion_mask>#.#</conversion_mask>
        <date_format_lenient>false</date_format_lenient>
        <date_format_locale/>
        <date_format_timezone/>
        <lenient_string_to_number>false</lenient_string_to_number>
        <encoding/>
        <decimal_symbol/>
        <grouping_symbol/>
        <currency_symbol/>
        <storage_type/>
      </meta>
      <meta>
        <name>p90_elapsed_ms</name>
        <rename/>
        <type>Number</type>
        <length>-1</length>
        <precision>2</precision>
        <conversion_mask>#.#</conversion_mask>
        <date_format_lenient>false</date_format_lenient>
        <date_format_locale/>
        <date_format_timezone/>
        <lenient_string_to_number>false</lenient_string_to_number>
        <encoding/>
        <decimal_symbol/>
        <grouping_symbol/>
        <currency_symbol/>
        <storage_type/>
      </meta>
    </fields>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>256</xloc>
      <yloc>96</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
  <step>
    <name>Filter Rows</name>
    <type>FilterRows</type>
    <description>Descarta requests_total &lt;= 0 o p90_elapsed_ms &lt; avg_elapsed_ms (FR-14).</description>
    <distribute>N</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <send_true_to/>
    <send_false_to/>
    <compare>
      <condition>
        <negated>N</negated>
        <conditions>
          <condition>
            <negated>N</negated>
            <leftvalue>requests_total</leftvalue>
            <function>&gt;</function>
            <value>
              <name/>
              <type>Integer</type>
              <text>0</text>
              <length>-1</length>
              <precision>-1</precision>
              <isnull>N</isnull>
              <mask/>
            </value>
          </condition>
          <condition>
            <operator>AND</operator>
            <negated>N</negated>
            <leftvalue>p90_elapsed_ms</leftvalue>
            <function>&gt;=</function>
            <rightvalue>avg_elapsed_ms</rightvalue>
          </condition>
        </conditions>
      </condition>
    </compare>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>416</xloc>
      <yloc>96</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
  <step>
    <name>Staging (Truncate)</name>
    <type>TableOutput</type>
    <description>Carga stg_kpi_endpoint_dia sin transformaciones adicionales, con Truncate (FR-14, FR-16).</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>sqlite_kpi</connection>
    <schema/>
    <table>stg_kpi_endpoint_dia</table>
    <commit>1000</commit>
    <truncate>Y</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>Y</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field/>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_monthly>Y</partitioning_monthly>
    <tablename_in_field>N</tablename_in_field>
    <tablename_field/>
    <tablename_in_table>Y</tablename_in_table>
    <return_keys>N</return_keys>
    <return_field/>
    <fields>
      <field>
        <column_name>date_utc</column_name>
        <stream_name>date_utc</stream_name>
      </field>
      <field>
        <column_name>endpoint_base</column_name>
        <stream_name>endpoint_base</stream_name>
      </field>
      <field>
        <column_name>requests_total</column_name>
        <stream_name>requests_total</stream_name>
      </field>
      <field>
        <column_name>success_2xx</column_name>
        <stream_name>success_2xx</stream_name>
      </field>
      <field>
        <column_name>client_4xx</column_name>
        <stream_name>client_4xx</stream_name>
      </field>
      <field>
        <column_name>server_5xx</column_name>
        <stream_name>server_5xx</stream_name>
      </field>
      <field>
        <column_name>parse_errors</column_name>
        <stream_name>parse_errors</stream_name>
      </field>
      <field>
        <column_name>avg_elapsed_ms</column_name>
        <stream_name>avg_elapsed_ms</stream_name>
      </field>
      <field>
        <column_name>p90_elapsed_ms</column_name>
        <stream_name>p90_elapsed_ms</stream_name>
      </field>
    </fields>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>576</xloc>
      <yloc>32</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
  <step>
    <name>Fact (Truncate)</name>
    <type>TableOutput</type>
    <description>Copia directa del flujo filtrado a fct_kpi_endpoint_dia, con Truncate (FR-14, FR-16).</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>sqlite_kpi</connection>
    <schema/>
    <table>fct_kpi_endpoint_dia</table>
    <commit>1000</commit>
    <truncate>Y</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>Y</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field/>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_monthly>Y</partitioning_monthly>
    <tablename_in_field>N</tablename_in_field>
    <tablename_field/>
    <tablename_in_table>Y</tablename_in_table>
    <return_keys>N</return_keys>
    <return_field/>
    <fields>
      <field>
        <column_name>date_utc</column_name>
        <stream_name>date_utc</stream_name>
      </field>
      <field>
        <column_name>endpoint_base</column_name>
        <stream_name>endpoint_base</stream_name>
      </field>
      <field>
        <column_name>requests_total</column_name>
        <stream_name>requests_total</stream_name>
      </field>
      <field>
        <column_name>success_2xx</column_name>
        <stream_name>success_2xx</stream_name>
      </field>
      <field>
        <column_name>client_4xx</column_name>
        <stream_name>client_4xx</stream_name>
      </field>
      <field>
        <column_name>server_5xx</column_name>
        <stream_name>server_5xx</stream_name>
      </field>
      <field>
        <column_name>parse_errors</column_name>
        <stream_name>parse_errors</stream_name>
      </field>
      <field>
        <column_name>avg_elapsed_ms</column_name>
        <stream_name>avg_elapsed_ms</stream_name>
      </field>
      <field>
        <column_name>p90_elapsed_ms</column_name>
        <stream_name>p90_elapsed_ms</stream_name>
      </field>
    </fields>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
    </remotesteps>
    <GUI>
      <xloc>576</xloc>
      <yloc>160</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
  <step_error_handling>
  </step_error_handling>
  <slave-step-copy-partition-distribution>
  </slave-step-copy-partition-distribution>
  <slave_transformation>N</slave_transformation>
</transformation>
